---
interface Props { t: any }
const { t } = Astro.props as Props;
---
<header class="hero">
  <div class="container hero-grid">
    <div class="hero-content">
      <div class="badge">
        <svg viewBox="0 0 24 24" width="12" height="12" fill="currentColor"><path d="M12 8v5l3 2"/><circle cx="12" cy="12" r="9" fill="none" stroke="currentColor" stroke-width="2"/></svg>
        {t.hero.badge}
      </div>
      <h1>{t.hero.title_line1}<br />{t.hero.title_line2}</h1>
      <p class="lead" set:html={t.hero.lead.replace(/⌥⌘4/g, '<kbd>⌥⌘4</kbd>')}></p>

      <div class="cta-row">
        <a class="btn btn-primary btn-lg" href="#beta">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M4 12l1.4-1.4L11 16.2V4h2v12.2l5.6-5.6L20 12l-8 8z"/></svg>
          {t.hero.cta_primary}
        </a>
        <a class="btn btn-outline btn-lg" href="#features">{t.hero.cta_secondary}</a>
      </div>

      <ul class="hero-meta">
        {t.hero.meta.map((m: string) => (<li><span class="dot dot-green"></span> {m}</li>))}
      </ul>
    </div>

    <a class="hero-shot-link" href="#beta" aria-label={t.hero.cta_primary}>
      <picture>
        <img src="/assets/editor-hero.png" alt="iSkitch editor with annotations" loading="lazy" width="1000" height="660" />
      </picture>
      <span class="hero-shot-badge">{t.hero.appstore_coming_top} {t.hero.appstore_coming_bottom}</span>
    </a>
  </div>
</header>
