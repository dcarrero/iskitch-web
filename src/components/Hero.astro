---
import AppStoreBadge from "./AppStoreBadge.astro";
interface Props { t: any }
const { t } = Astro.props as Props;
// Heros generados con la app real (tools/make_hero_screenshots.sh).
// Si llega un código sin asset (ej. nuevo idioma sin captura todavía), caemos a EN.
const availableHeroLangs = ['en', 'es', 'fr', 'de', 'it', 'pt', 'ja', 'ko'];
const slug = availableHeroLangs.includes(t.lang) ? t.lang : 'en';
const heroBase = `/assets/editor-hero-${slug}`;
const heroImage = `${heroBase}.png`;          // PNG original (lightbox)
const heroLargeWebp = `${heroBase}-2240.webp`; // WebP máxima para lightbox
const heroSrcset = `${heroBase}-800.webp 800w, ${heroBase}-1280.webp 1280w, ${heroBase}-1600.webp 1600w`;
---
<header class="hero">
  <div class="container hero-grid">
    <div class="hero-content">
      <div class="badge">
        <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 8v5l3 2"/></svg>
        {t.hero.badge}
      </div>
      <h1>{t.hero.title_line1}<br />{t.hero.title_line2}</h1>
      <p class="lead" set:html={t.hero.lead.replace(/⌥⌘4/g, '<kbd>⌥⌘4</kbd>')}></p>

      <div class="cta-row">
        <AppStoreBadge t={t} size="lg" />
        <a class="btn btn-outline btn-lg" href="#features">{t.hero.cta_secondary}</a>
      </div>

      <ul class="hero-meta">
        {t.hero.meta.map((m: string) => (<li><span class="dot dot-green"></span> {m}</li>))}
      </ul>
    </div>

    <button class="hero-shot-link" type="button" data-lightbox-src={heroLargeWebp} data-lightbox-alt={t.hero.image_alt} aria-label="Expand screenshot">
      <picture>
        <source
          type="image/webp"
          srcset={heroSrcset}
          sizes="(max-width: 768px) 92vw, (max-width: 1180px) 50vw, 560px" />
        <img
          src={`${heroBase}-1280.webp`}
          alt={t.hero.image_alt}
          fetchpriority="high"
          decoding="async"
          width="1000"
          height="660" />
      </picture>
      <span class="hero-shot-badge">{t.hero.appstore_coming_top} {t.hero.appstore_coming_bottom}</span>
      <span class="hero-shot-zoom" aria-hidden="true">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3M11 8v6M8 11h6"/></svg>
      </span>
    </button>
  </div>
</header>

<!-- Lightbox -->
<div class="lightbox" id="lightbox" role="dialog" aria-hidden="true" aria-modal="true">
  <button class="lightbox-close" type="button" aria-label="Close">
    <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M6 6l12 12M18 6L6 18"/></svg>
  </button>
  <img class="lightbox-img" alt="" />
</div>

<script is:inline>
  (function () {
    const triggers = document.querySelectorAll('[data-lightbox-src]');
    const lightbox = document.getElementById('lightbox');
    if (!lightbox) return;
    const lbImg = lightbox.querySelector('.lightbox-img');
    const lbClose = lightbox.querySelector('.lightbox-close');
    // Quién abrió el diálogo: al cerrar hay que devolverle el foco.
    let lastTrigger = null;
    function open(src, alt, trigger) {
      lastTrigger = trigger || null;
      lbImg.src = src;
      lbImg.alt = alt || '';
      lightbox.classList.add('is-open');
      lightbox.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      lbClose.focus();
    }
    function close() {
      if (!lightbox.classList.contains('is-open')) return;
      lightbox.classList.remove('is-open');
      lightbox.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      setTimeout(() => { lbImg.src = ''; }, 200);
      if (lastTrigger) { lastTrigger.focus(); lastTrigger = null; }
    }
    triggers.forEach((el) => el.addEventListener('click', (e) => {
      e.preventDefault();
      open(el.getAttribute('data-lightbox-src'), el.getAttribute('data-lightbox-alt'), el);
    }));
    lbClose.addEventListener('click', close);
    lightbox.addEventListener('click', (e) => { if (e.target === lightbox) close(); });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') { close(); return; }
      // Mientras el diálogo está abierto el foco no sale de él: el único
      // control es el botón de cerrar, así que el tab vuelve siempre a él.
      if (e.key === 'Tab' && lightbox.classList.contains('is-open')) {
        e.preventDefault();
        lbClose.focus();
      }
    });
  })();
</script>
