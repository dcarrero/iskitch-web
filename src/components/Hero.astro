---
interface Props { t: any }
const { t } = Astro.props as Props;
---
<header class="hero">
  <div class="container">
    <div class="badge">
      <svg viewBox="0 0 24 24" width="12" height="12" fill="currentColor"><path d="M12 2 14 8 20 9 16 13 17 19 12 16 7 19 8 13 4 9 10 8 Z"/></svg>
      {t.hero.badge}
    </div>
    <h1>{t.hero.title_line1}<br />{t.hero.title_line2}</h1>
    <p class="lead" set:html={t.hero.lead.replace(/⌥⌘4/g, '<kbd>⌥⌘4</kbd>')}></p>

    <div class="cta-row">
      <a class="btn btn-dark btn-lg" id="download" href="#">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M17.55 12.5c0-2.45 2-3.62 2.1-3.68a4.45 4.45 0 0 0-3.51-1.9c-1.5-.15-2.93.88-3.69.88-.78 0-1.94-.86-3.2-.84A4.7 4.7 0 0 0 5.3 9.3c-1.7 2.94-.43 7.3 1.22 9.7.81 1.18 1.78 2.5 3.05 2.45 1.23-.05 1.7-.79 3.18-.79s1.9.79 3.2.76c1.32-.02 2.16-1.2 2.96-2.4a10.6 10.6 0 0 0 1.36-2.78 4.3 4.3 0 0 1-2.72-3.74Zm-2.46-6.85a4.27 4.27 0 0 0 1-3.15 4.4 4.4 0 0 0-2.86 1.48 4.06 4.06 0 0 0-1.02 3.07 3.66 3.66 0 0 0 2.88-1.4Z"/></svg>
        <span class="cta-stack"><small>{t.hero.cta_top}</small><strong>{t.hero.cta_bottom}</strong></span>
      </a>
      <a class="btn btn-outline btn-lg" href="#features">{t.hero.cta_secondary}</a>
    </div>

    <ul class="hero-meta">
      {t.hero.meta.map((m: string) => (<li><span class="dot dot-green"></span> {m}</li>))}
    </ul>
  </div>
</header>

<section class="hero-shot">
  <div class="container">
    <picture>
      <img src="/assets/editor-hero.png" alt="iSkitch editor" loading="lazy" />
    </picture>
  </div>
</section>
