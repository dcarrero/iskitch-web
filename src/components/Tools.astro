---
interface Props { t: any }
const { t } = Astro.props as Props;
// Iconos pareados con los SF Symbols del sidebar de la app (outline, currentColor).
const toolIcons = [
  // Select — cursorarrow
  '<svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M4 3l7 18 2.3-7.5 7.7-2.5L4 3z"/></svg>',
  // Arrow — arrow.up.right
  '<svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M9 7h8v8"/></svg>',
  // Text — textformat
  '<svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M4 7V5h16v2M12 5v14M9 19h6"/></svg>',
  // Rectangle — rectangle
  '<svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.7"><rect x="3" y="6" width="18" height="12" rx="1.8"/></svg>',
  // Ellipse — circle
  '<svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.7"><circle cx="12" cy="12" r="9"/></svg>',
  // Line — line.diagonal
  '<svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"><line x1="5" y1="19" x2="19" y2="5"/></svg>',
  // Highlight — highlighter
  '<svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M15 4l5 5-8 8H7v-5l8-8z"/><path d="M12 7l5 5M4 21h6"/></svg>',
  // Pixelate — checkerboard.rectangle
  '<svg viewBox="0 0 24 24" width="22" height="22"><g fill="currentColor"><rect x="3" y="3" width="8" height="8" rx="1"/><rect x="13" y="13" width="8" height="8" rx="1"/></g><g fill="none" stroke="currentColor" stroke-width="1.7"><rect x="13" y="3" width="8" height="8" rx="1"/><rect x="3" y="13" width="8" height="8" rx="1"/></g></svg>',
  // Stamp — checkmark.seal.fill (sello con check)
  '<svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2.5l1.8 2.1 2.8-.4.8 2.6 2.6.8-.4 2.8 2.1 1.8-2.1 1.8.4 2.8-2.6.8-.8 2.6-2.8-.4L12 21.5l-1.8-2.1-2.8.4-.8-2.6-2.6-.8.4-2.8L2.3 12l2.1-1.8-.4-2.8 2.6-.8.8-2.6 2.8.4L12 2.5z"/><path d="M8.5 12.2l2.4 2.4 4.6-4.6"/></svg>',
  // Pen — scribble
  '<svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M3 14c2-3 3.8-3 5.5 0s3.5 3 5.5 0 4-3 7-2"/></svg>',
  // Spotlight — viewfinder
  '<svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M4 8V5a1 1 0 0 1 1-1h3M16 4h3a1 1 0 0 1 1 1v3M20 16v3a1 1 0 0 1-1 1h-3M8 20H5a1 1 0 0 1-1-1v-3"/><circle cx="12" cy="12" r="3"/></svg>',
  // Sticker — face.smiling
  '<svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><circle cx="9" cy="9.5" r="1" fill="currentColor" stroke="none"/><circle cx="15" cy="9.5" r="1" fill="currentColor" stroke="none"/></svg>',
  // Image — photo
  '<svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="16" rx="2"/><circle cx="8.5" cy="9" r="1.5"/><path d="M3 17l5-5 4 4 3-3 6 6"/></svg>',
  // Crop — crop
  '<svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M7 2v15a1 1 0 0 0 1 1h15M2 7h15a1 1 0 0 1 1 1v14"/></svg>'
];
---
<section id="tools" class="tools">
  <div class="container">
    <div class="section-head">
      <h2>{t.tools.title}</h2>
      <p class="lead">{t.tools.lead}</p>
    </div>

    <div class="tools-grid">
      {t.tools.names.map((name: string, i: number) => (
        <div class="tool">
          <div class="tool-box" aria-hidden="true" set:html={toolIcons[i]}></div>
          <span>{name}</span>
        </div>
      ))}
    </div>
  </div>
</section>
