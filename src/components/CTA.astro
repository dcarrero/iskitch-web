---
import AppStoreBadge from "./AppStoreBadge.astro";
interface Props { t: any }
const { t } = Astro.props as Props;
---
<section class="cta">
  <div class="container">
    <h2>{t.cta.title}</h2>
    <p>{t.cta.lead}</p>
    <div class="cta-badge">
      <AppStoreBadge t={t} size="lg" />
    </div>
  </div>
</section>
