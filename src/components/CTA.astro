---
interface Props { t: any }
const { t } = Astro.props as Props;
---
<section class="cta">
  <div class="container">
    <h2>{t.cta.title}</h2>
    <p>{t.cta.lead}</p>
    <a class="btn btn-white btn-lg" href="#beta">
      <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M4 12l1.4-1.4L11 16.2V4h2v12.2l5.6-5.6L20 12l-8 8z"/></svg>
      <strong>{t.cta.button}</strong>
    </a>
  </div>
</section>
