---
import "../styles/global.css";
interface Props {
  t: any;
  /** Si está activo, generamos el JSON-LD SoftwareApplication (solo para la home). */
  isHome?: boolean;
  /** Ruta de la versión markdown de esta página (relativa a site). Si se omite,
      no añadimos <link rel="alternate" type="text/markdown">. */
  markdownPath?: string;
  /** Tipo Open Graph. Por defecto 'website'; los artículos usan 'article'. */
  ogType?: string;
  /** Alternates hreflang específicos de esta página. Si se omiten, usamos los
      de la home. Cada artículo del blog pasa los suyos (una URL por idioma). */
  alternates?: { hreflang: string; href: string }[];
  /** JSON-LD de artículo (BlogPosting) que sustituye al WebPage por defecto. */
  articleSchema?: Record<string, unknown>;
  /** Imagen OG/Twitter. Ruta absoluta (relativa a site). Por defecto la portada. */
  ogImage?: string;
}
const { t, isHome = false, markdownPath, ogType = "website", alternates, articleSchema, ogImage } = Astro.props as Props;
const site = "https://iskitch.com";
const ogImageUrl = `${site}${ogImage ?? "/og-cover.png"}`;
const path = Astro.url.pathname.replace(/\/+$/, "") || "/";
const canonical = `${site}${path === "/" ? "/" : `${path}/`}`;

// JSON-LD: SoftwareApplication para la home, WebPage para el resto + Organization siempre.
const organization = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "@id": `${site}/#organization`,
  "name": "Color Vivo Internet, S.L.",
  "url": site,
  "logo": `${site}/favicon.png`,
  "email": "hello@iskitch.com",
  "address": { "@type": "PostalAddress", "addressLocality": "Madrid", "addressCountry": "ES" }
};

const homeSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "iSkitch",
  "applicationCategory": "ProductivityApplication",
  "operatingSystem": "macOS 14 or later",
  "description": t.meta.description,
  "url": canonical,
  "inLanguage": t.lang,
  "offers": { "@type": "Offer", "price": t.pricing.price_amount, "priceCurrency": t.pricing.price_currency, "availability": "https://schema.org/InStock", "url": t.appstore.url },
  "downloadUrl": t.appstore.url,
  "softwareVersion": "1.3.0",
  "publisher": { "@id": `${site}/#organization` },
  "image": `${site}/og-cover.png`
};

const pageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": t.meta.title,
  "description": t.meta.description,
  "url": canonical,
  "inLanguage": t.lang,
  "isPartOf": { "@type": "WebSite", "name": "iSkitch", "url": site },
  "publisher": { "@id": `${site}/#organization` }
};
const jsonLd = isHome
  ? [homeSchema, organization]
  : articleSchema
    ? [articleSchema, organization]
    : [pageSchema, organization];

// Lista de alternates: la propia de la página si se pasa, o la de la home por defecto.
const homeAlternates = [
  { hreflang: "en", href: `${site}/` },
  { hreflang: "es", href: `${site}/es/` },
  { hreflang: "fr", href: `${site}/fr/` },
  { hreflang: "de", href: `${site}/de/` },
  { hreflang: "it", href: `${site}/it/` },
  { hreflang: "pt", href: `${site}/pt/` },
  { hreflang: "ja", href: `${site}/ja/` },
  { hreflang: "ko", href: `${site}/ko/` },
];
const altLinks = alternates ?? homeAlternates;
const xDefault = (alternates ?? homeAlternates).find((a) => a.hreflang === "en")?.href ?? `${site}/`;
---
<!doctype html>
<html lang={t.lang}>
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>{t.meta.title}</title>
<meta name="description" content={t.meta.description} />
<meta name="theme-color" content="#FF3366" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
<link rel="manifest" href="/site.webmanifest" />
<link rel="canonical" href={canonical} />
<meta property="og:title" content={t.meta.title} />
<meta property="og:description" content={t.meta.description} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:type" content={ogType} />
<meta property="og:url" content={canonical} />
<meta property="og:locale" content={
  t.lang === 'es' ? 'es_ES' :
  t.lang === 'fr' ? 'fr_FR' :
  t.lang === 'de' ? 'de_DE' :
  t.lang === 'it' ? 'it_IT' :
  t.lang === 'pt' ? 'pt_PT' :
  t.lang === 'ja' ? 'ja_JP' :
  t.lang === 'ko' ? 'ko_KR' :
  'en_US'
} />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:image" content={ogImageUrl} />
{altLinks.map((a) => (
  <link rel="alternate" hreflang={a.hreflang} href={a.href} />
))}
<link rel="alternate" hreflang="x-default" href={xDefault} />
{markdownPath && (
  <link rel="alternate" type="text/markdown" href={`${site}${markdownPath}`} title="Markdown version (Markdown for Agents)" />
)}
<link rel="preload" href="/fonts/inter-variable-latin.woff2" as="font" type="font/woff2" crossorigin />
<script type="application/ld+json" set:html={JSON.stringify(jsonLd)}></script>
<!-- Google Analytics (GA4) — cargado async, no bloquea el render -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-D3L2G7Z90J"></script>
<script is:inline>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', 'G-D3L2G7Z90J');
</script>
</head>
<body>
<slot />
</body>
</html>
</content>
</invoke>