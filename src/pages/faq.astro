---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Faq from "../components/Faq.astro";
import Footer from "../components/Footer.astro";
import baseT from "../i18n/en.json";
const t = { ...baseT,
  switcher: { label: "ES", href: "/es/faq" },
  meta: {
    title: "FAQ — iSkitch",
    description: "Frequently asked questions about iSkitch: pricing, supported macOS, languages, permissions, privacy and more."
  }
};
---
<Layout t={t}>
  <Nav t={t} />
  <Faq t={t} />
  <Footer t={t} />
</Layout>
