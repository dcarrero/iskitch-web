---
import Layout from "../../layouts/Layout.astro";
import Nav from "../../components/Nav.astro";
import Changelog from "../../components/Changelog.astro";
import Footer from "../../components/Footer.astro";
import baseT from "../../i18n/de.json";
const t = { ...baseT,
  switcher: { label: "EN", href: "/changelog" },
  meta: {
    title: "Änderungen — iSkitch",
    description: "iSkitch-Versionshinweise — jede Version und was sich geändert hat, neueste zuerst."
  }
};
---
<Layout t={t}>
  <Nav t={t} />
  <Changelog t={t} />
  <Footer t={t} />
</Layout>
