---
import Layout from "../../layouts/Layout.astro";
import Nav from "../../components/Nav.astro";
import Faq from "../../components/Faq.astro";
import Footer from "../../components/Footer.astro";
import baseT from "../../i18n/ko.json";
const t = { ...baseT,
  switcher: { label: "EN", href: "/faq" },
  meta: {
    title: "자주 묻는 질문 — iSkitch",
    description: "iSkitch 자주 묻는 질문: 가격, 지원 macOS, 언어, 권한, 프라이버시 등."
  }
};
---
<Layout t={t}>
  <Nav t={t} />
  <Faq t={t} />
  <Footer t={t} />
</Layout>
