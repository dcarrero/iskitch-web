---
import Layout from "../../layouts/Layout.astro";
import Nav from "../../components/Nav.astro";
import Changelog from "../../components/Changelog.astro";
import Footer from "../../components/Footer.astro";
import baseT from "../../i18n/it.json";
const t = { ...baseT,
  switcher: { label: "EN", href: "/changelog" },
  meta: {
    title: "Novità — iSkitch",
    description: "Note di versione di iSkitch — tutte le versioni e cosa è cambiato, dalla più recente alla prima."
  }
};
---
<Layout t={t}>
  <Nav t={t} />
  <Changelog t={t} />
  <Footer t={t} />
</Layout>
