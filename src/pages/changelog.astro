---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Changelog from "../components/Changelog.astro";
import Footer from "../components/Footer.astro";
import baseT from "../i18n/en.json";
const t = { ...baseT,
  switcher: { label: "ES", href: "/es/changelog" },
  meta: {
    title: "Changelog — iSkitch",
    description: "iSkitch release notes — every version and what changed, newest first."
  }
};
---
<Layout t={t}>
  <Nav t={t} />
  <Changelog t={t} />
  <Footer t={t} />
</Layout>
