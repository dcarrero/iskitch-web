---
import Layout from "../../layouts/Layout.astro";
import Nav from "../../components/Nav.astro";
import Changelog from "../../components/Changelog.astro";
import Footer from "../../components/Footer.astro";
import baseT from "../../i18n/ja.json";
const t = { ...baseT,
  switcher: { label: "EN", href: "/changelog" },
  meta: {
    title: "更新履歴 — iSkitch",
    description: "iSkitch のリリースノート — 各バージョンの変更点を新しい順に。"
  }
};
---
<Layout t={t}>
  <Nav t={t} />
  <Changelog t={t} />
  <Footer t={t} />
</Layout>
