---
import Layout from "../../layouts/Layout.astro";
import Nav from "../../components/Nav.astro";
import Faq from "../../components/Faq.astro";
import Footer from "../../components/Footer.astro";
import baseT from "../../i18n/fr.json";
const t = { ...baseT,
  switcher: { label: "EN", href: "/faq" },
  meta: {
    title: "Questions fréquentes — iSkitch",
    description: "Questions fréquentes sur iSkitch : tarif, macOS pris en charge, langues, autorisations, confidentialité et plus."
  }
};
---
<Layout t={t}>
  <Nav t={t} />
  <Faq t={t} />
  <Footer t={t} />
</Layout>
