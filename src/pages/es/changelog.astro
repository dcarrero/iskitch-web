---
import Layout from "../../layouts/Layout.astro";
import Nav from "../../components/Nav.astro";
import Changelog from "../../components/Changelog.astro";
import Footer from "../../components/Footer.astro";
import baseT from "../../i18n/es.json";
const t = { ...baseT,
  switcher: { label: "EN", href: "/changelog" },
  meta: {
    title: "Novedades — iSkitch",
    description: "Notas de versión de iSkitch — todas las versiones y qué cambió, de la más reciente a la primera."
  }
};
---
<Layout t={t}>
  <Nav t={t} />
  <Changelog t={t} />
  <Footer t={t} />
</Layout>
