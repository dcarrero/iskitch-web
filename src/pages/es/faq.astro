---
import Layout from "../../layouts/Layout.astro";
import Nav from "../../components/Nav.astro";
import Faq from "../../components/Faq.astro";
import Footer from "../../components/Footer.astro";
import baseT from "../../i18n/es.json";
const t = { ...baseT,
  switcher: { label: "EN", href: "/faq" },
  meta: {
    title: "Preguntas frecuentes — iSkitch",
    description: "Preguntas frecuentes sobre iSkitch: precio, macOS compatible, idiomas, permisos, privacidad y más."
  }
};
---
<Layout t={t}>
  <Nav t={t} />
  <Faq t={t} />
  <Footer t={t} />
</Layout>
