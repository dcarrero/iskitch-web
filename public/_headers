# Fuente local — cache largo (es immutable, no cambia).
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# WebP y PNG del hero — cache razonable.
/assets/*.webp
  Cache-Control: public, max-age=604800
/assets/*.png
  Cache-Control: public, max-age=604800
